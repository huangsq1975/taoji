<view class="page-wrap">
  <navigation-bar title="我的" background="#fff" color="#172033" />

  <scroll-view scroll-y class="scroll-area">
    <!-- Profile header -->
    <view class="profile-card">
      <view class="avatar"><text class="avatar-icon">👤</text></view>
      <view class="profile-info">
        <text class="profile-name">{{name || '微信用户'}}</text>
        <text class="profile-stage" wx:if="{{statusLabel}}">{{statusLabel}}</text>
        <text class="profile-stage" wx:else>韬纪元AI 客户</text>
      </view>
      <view class="login-badge"><text>已登录</text></view>
    </view>

    <!-- Documents -->
    <view class="card">
      <text class="card-title">资料概览</text>
      <view class="info-row">
        <text class="label">个人资料</text>
        <text class="value">{{personalDocSummary}}</text>
      </view>
      <view class="info-row">
        <text class="label">企业资料</text>
        <text class="value">{{businessDocSummary}}</text>
      </view>
      <view class="info-row">
        <text class="label">已上传</text>
        <text class="value">{{loading ? '加载中…' : docCount + ' 份文件'}}</text>
      </view>
      <view class="info-row" wx:if="{{docCompleteness > 0}}">
        <text class="label">资料完整度</text>
        <text class="value completeness">{{docCompleteness}}%</text>
      </view>
    </view>

    <!-- Service info -->
    <view class="card">
      <text class="card-title">服务信息</text>
      <view class="info-row">
        <text class="label">当前顾问</text>
        <text class="value">{{advisorName ? advisorName + ' · 韬纪元AI' : '暂无顾问'}}</text>
      </view>
      <view class="info-row" wx:if="{{statusLabel}}">
        <text class="label">办理阶段</text>
        <text class="value">{{statusLabel}}</text>
      </view>
      <view class="info-row" wx:if="{{financingNeed}}">
        <text class="label">融资方向</text>
        <text class="value">{{financingNeed}}</text>
      </view>
      <view class="info-row" wx:if="{{loanAmountLabel}}">
        <text class="label">目标金额</text>
        <text class="value">{{loanAmountLabel}}</text>
      </view>
    </view>

    <!-- Quick links -->
    <view class="card">
      <text class="card-title">快速入口</text>
      <view class="link-row" bindtap="onProgressTap">
        <text class="link-label">办理进度</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-row" bindtap="onAdvisorTap">
        <text class="link-label">联系顾问</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-row" bindtap="onAuthTap">
        <text class="link-label">资料授权管理</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-row" bindtap="onHistoryTap">
        <text class="link-label">历史对话</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <!-- Logout -->
    <view class="card">
      <view class="logout-btn" bindtap="onLogout"><text>退出登录</text></view>
    </view>

    <view style="height: 20rpx" />
  </scroll-view>
</view>
