<view class="page-wrap">
  <navigation-bar title="我的" background="#fff" color="#172033" />

  <scroll-view scroll-y class="scroll-area">
    <!-- Profile header -->
    <view class="profile-card">
      <view class="avatar"><text class="avatar-icon">👤</text></view>
      <view class="profile-info">
        <text class="profile-name">{{user.name}}</text>
        <text class="profile-phone">{{user.phone}}</text>
      </view>
      <view class="login-badge"><text>已登录</text></view>
    </view>

    <!-- Documents -->
    <view class="card">
      <text class="card-title">个人/企业资料</text>
      <view class="info-row"><text class="label">个人资料</text><text class="value">身份证明、手机号、联系人</text></view>
      <view class="info-row"><text class="label">企业资料</text><text class="value">营业执照、经营信息</text></view>
      <view class="info-row"><text class="label">资料空间</text><text class="value">{{user.storage}}</text></view>
    </view>

    <!-- Service info -->
    <view class="card">
      <text class="card-title">服务信息</text>
      <view class="info-row"><text class="label">当前顾问</text><text class="value">{{user.advisor}} · 韬纪元AI</text></view>
      <view class="info-row"><text class="label">资料状态</text><text class="value">{{user.currentStage}}</text></view>
      <view class="info-row"><text class="label">最近进度</text><text class="value">{{user.latestProgress}}</text></view>
    </view>

    <!-- Quick links -->
    <view class="card">
      <text class="card-title">快速入口</text>
      <view class="link-row" bindtap="onAdvisorTap">
        <text class="link-label">联系顾问</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-row" bindtap="onAuthTap">
        <text class="link-label">资料授权管理</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="link-row" bindtap="onHistoryTap">
        <text class="link-label">历史对话</text>
        <text class="link-arrow">›</text>
      </view>
    </view>

    <!-- Settings -->
    <view class="card">
      <text class="card-title">设置</text>
      <view class="info-row"><text class="label">通知偏好</text><text class="value">资料进展、顾问留言</text></view>
      <view class="info-row"><text class="label">隐私协议</text><text class="value">已同意 · 查看详情</text></view>
      <view class="info-row"><text class="label">帮助中心</text><text class="value">常见问题、联系客服</text></view>
    </view>

    <!-- Logout -->
    <view class="card">
      <view class="logout-btn" bindtap="onLogout"><text>退出登录</text></view>
    </view>

    <view style="height: 20rpx" />
  </scroll-view>


</view>
