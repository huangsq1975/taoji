<view class="page-wrap">
  <navigation-bar title="办理进度" background="#fff" color="#172033" />

  <scroll-view scroll-y class="scroll-area">
    <!-- Current status -->
    <view class="card">
      <text class="card-title">当前状态</text>
      <view class="info-row">
        <text class="label">当前阶段</text>
        <text class="value blue">{{loading ? '加载中…' : currentStage}}</text>
      </view>
      <view class="info-row" wx:if="{{!loading && blocker}}">
        <text class="label">当前情况</text>
        <text class="value">{{blocker}}</text>
      </view>
      <view class="info-row" wx:if="{{!loading && nextStep}}">
        <text class="label">下一步</text>
        <text class="value">{{nextStep}}</text>
      </view>
    </view>

    <!-- Timeline -->
    <view class="card">
      <text class="card-title">服务时间线</text>
      <view class="timeline">
        <view
          wx:for="{{steps}}"
          wx:key="label"
          class="timeline-item {{item.status}}"
        >
          <view class="timeline-dot-wrap">
            <view class="timeline-dot" />
            <view class="timeline-line" wx:if="{{index < steps.length - 1}}" />
          </view>
          <view class="timeline-content">
            <text class="timeline-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Uploaded documents -->
    <view class="card" wx:if="{{!loading}}">
      <text class="card-title">已上传资料</text>
      <view wx:if="{{uploadedDocs.length === 0}}" class="empty-hint">
        <text>暂无上传资料，点击下方按钮开始上传</text>
      </view>
      <view
        wx:for="{{uploadedDocs}}"
        wx:key="fileName"
        class="doc-item"
      >
        <view class="doc-info">
          <text class="doc-name">{{item.docTypeLabel}}</text>
          <text class="doc-desc">{{item.fileName}}</text>
        </view>
        <view class="badge {{item.aiParseStatus === 'DONE' ? 'badge-ok' : item.aiParseStatus === 'FAILED' ? 'badge-fail' : 'badge-warn'}}">
          <text>{{item.aiParseStatusLabel}}</text>
        </view>
      </view>
    </view>

    <!-- Advisor message -->
    <view class="card" wx:if="{{latestFollowUp}}">
      <text class="card-title">顾问留言</text>
      <view class="advisor-msg-box">
        <text class="advisor-name">{{latestFollowUp.advisorName}}：</text>
        <text class="advisor-msg-text">{{latestFollowUp.content}}</text>
        <text class="advisor-msg-time">{{latestFollowUp.createdAt}}</text>
      </view>
    </view>

    <!-- Upload button -->
    <view class="card">
      <view class="pill-btn pill-btn-primary" bindtap="onUploadTap">
        <text>上传资料</text>
      </view>
    </view>

    <view style="height: 20rpx" />
  </scroll-view>
</view>
