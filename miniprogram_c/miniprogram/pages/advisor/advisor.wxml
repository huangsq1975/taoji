<view class="page-wrap">
  <navigation-bar title="联系顾问" background="#fff" color="#172033" />
  <scroll-view scroll-y class="scroll-area">

    <view wx:if="{{loading}}" class="state-tip">加载中…</view>

    <view wx:elif="{{!hasAdvisor}}" class="state-tip">暂未分配顾问，请联系平台客服</view>

    <block wx:else>
      <view class="card">
        <view class="advisor-profile">
          <view class="advisor-avatar"><text class="avatar-icon">👨‍💼</text></view>
          <view class="advisor-info">
            <text class="advisor-name">{{advisorName}}</text>
            <text class="advisor-role">韬纪元AI · 助贷顾问</text>
          </view>
        </view>
      </view>

      <view class="card" wx:if="{{advisorMessage}}">
        <text class="card-title">顾问留言</text>
        <view class="msg-box">
          <text class="msg-sender">{{advisorName}}：</text>
          <text class="msg-content">{{advisorMessage}}</text>
        </view>
      </view>

      <view class="card">
        <view class="btn-row">
          <view class="contact-btn phone-btn" bindtap="onPhoneCall">
            <text>📞 电话联系</text>
          </view>
          <view class="contact-btn wechat-btn" bindtap="onWechatTap">
            <text>💬 微信联系</text>
          </view>
        </view>
      </view>
    </block>

  </scroll-view>
</view>
