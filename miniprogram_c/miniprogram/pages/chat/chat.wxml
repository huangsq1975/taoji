<view class="page-wrap">
  <!-- Top Bar -->
  <view class="topbar" style="padding-top: {{statusBarHeight}}px">
    <view class="topbar-left">
      <view class="icon-btn" bindtap="onMenuTap">
        <text class="icon-text">☰</text>
      </view>
      <view class="icon-btn" bindtap="onNewChat">
        <text class="icon-text">✎</text>
      </view>
    </view>
    <text class="topbar-brand">韬纪元AI</text>
    <view class="topbar-right" />
  </view>

  <!-- Chat area -->
  <view class="chat-area">
    <!-- Welcome screen -->
    <view class="welcome" wx:if="{{messages.length === 0}}">
      <view class="welcome-logo">
        <text class="logo-icon">🤖</text>
      </view>
      <text class="welcome-title">{{userName}}，有什么我可以帮你的？</text>
      <text class="welcome-sub">分析流水、评估信用、推荐融资方案，直接说需求或上传资料</text>
      <view class="pill-list">
        <view
          wx:for="{{quickPills}}"
          wx:key="*this"
          class="quick-pill"
          bindtap="onPillTap"
          data-text="{{item}}"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- Message list -->
    <scroll-view
      wx:else
      scroll-y
      class="msg-scroll"
      scroll-into-view="{{scrollToId}}"
      scroll-with-animation
    >
      <view class="msg-list">
        <view
          wx:for="{{messages}}"
          wx:key="id"
          id="{{item.id}}"
          class="msg-wrap {{item.role === 'user' ? 'msg-wrap-user' : 'msg-wrap-ai'}}"
        >
          <view wx:if="{{item.role === 'ai'}}" class="ai-label">韬纪元AI</view>
          <view class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
            <text class="msg-text" selectable>{{item.content}}</text>
          </view>
          <text wx:if="{{item.time}}" class="msg-time">{{item.time}}</text>
        </view>
      </view>
      <view style="height: 180rpx" />
    </scroll-view>
  </view>

  <!-- Input bar -->
  <view class="input-bar">
    <view class="icon-btn gray" bindtap="onUploadTap">
      <text class="icon-text">⊕</text>
    </view>
    <input
      class="input-field"
      placeholder="描述您的融资需求..."
      placeholder-class="input-placeholder"
      value="{{inputValue}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="onSendTap"
      adjust-position
    />
    <view class="send-btn {{inputValue ? 'send-btn-active' : ''}}" bindtap="onSendTap">
      <text class="send-icon">➤</text>
    </view>
  </view>

  <!-- Tab bar -->
  <tab-bar active-tab="chat" />

  <!-- Sidebar overlay -->
  <view wx:if="{{sidebarVisible}}" class="sidebar-mask" bindtap="onSidebarMaskTap">
    <view class="sidebar" catchtap="">
      <view class="sidebar-header">
        <text class="sidebar-title">韬纪元AI</text>
      </view>
      <view class="sidebar-section">
        <text class="sidebar-section-label">工具入口</text>
        <view class="sidebar-item" bindtap="onUploadTap">
          <text class="sidebar-icon">📁</text>
          <text class="sidebar-item-label">上传资料</text>
        </view>
        <view class="sidebar-item" bindtap="onCreditTap">
          <text class="sidebar-icon">🏦</text>
          <text class="sidebar-item-label">企业征信查询</text>
        </view>
        <view class="sidebar-item" bindtap="onProgressTap">
          <text class="sidebar-icon">📋</text>
          <text class="sidebar-item-label">查看进度</text>
        </view>
        <view class="sidebar-item" bindtap="onAdvisorTap">
          <text class="sidebar-icon">👨‍💼</text>
          <text class="sidebar-item-label">联系顾问</text>
        </view>
        <view class="sidebar-item" bindtap="onNotifyTap">
          <text class="sidebar-icon">🔔</text>
          <text class="sidebar-item-label">消息通知</text>
        </view>
      </view>
      <view class="sidebar-divider" />
      <view class="sidebar-section">
        <text class="sidebar-section-label">个人</text>
        <view class="sidebar-item" bindtap="onAuthTap">
          <text class="sidebar-icon">🔐</text>
          <text class="sidebar-item-label">资料授权</text>
        </view>
        <view class="sidebar-item" bindtap="onHistoryTap">
          <text class="sidebar-icon">🕐</text>
          <text class="sidebar-item-label">历史对话</text>
        </view>
      </view>
      <view class="sidebar-footer" bindtap="onMineTap">
        <view class="sidebar-avatar">
          <text>👤</text>
        </view>
        <text class="sidebar-user-name">{{userName}}</text>
      </view>
    </view>
  </view>

  <!-- Upload sheet -->
  <view wx:if="{{uploadSheetVisible}}" class="sheet-mask" bindtap="onUploadSheetClose">
    <view class="sheet" catchtap="">
      <view class="sheet-item" bindtap="onUploadChoose" data-type="camera">
        <text class="sheet-icon">📷</text>
        <text>拍照</text>
      </view>
      <view class="sheet-item" bindtap="onUploadChoose" data-type="local">
        <text class="sheet-icon">📄</text>
        <text>手机本地文件</text>
      </view>
      <view class="sheet-item" bindtap="onUploadChoose" data-type="wechat">
        <text class="sheet-icon">💬</text>
        <text>从微信聊天记录中选择</text>
      </view>
      <view class="sheet-gap" />
      <view class="sheet-cancel" bindtap="onUploadSheetClose">
        <text>取消</text>
      </view>
    </view>
  </view>
</view>
