<view class="page-wrap">
  <navigation-bar title="资料授权" background="#fff" color="#172033" />
  <scroll-view scroll-y class="scroll-area">
    <text class="desc">统一管理您的资料授权状态，确保融资申请资料整理正常进行。</text>

    <view class="card">
      <view wx:for="{{authItems}}" wx:key="name" class="auth-item">
        <view class="auth-header">
          <view class="auth-title-wrap">
            <text class="auth-name">{{item.name}}</text>
            <text class="auth-desc">{{item.desc}}</text>
          </view>
          <text class="auth-status status-{{item.status}}">{{item.statusLabel}}</text>
        </view>
        <view class="auth-meta">
          <text class="auth-target">授权对象：{{item.target}}</text>
          <text wx:if="{{item.time}}" class="auth-time">授权时间：{{item.time}}</text>
        </view>
        <view wx:if="{{item.status === 'pending'}}" class="auth-action" bindtap="onUploadAuth">
          <text>上传授权文件</text>
        </view>
        <view wx:elif="{{item.status === 'not_applied'}}" class="auth-action" bindtap="onApplyAuth" data-name="{{item.name}}">
          <text>发起授权</text>
        </view>
        <view wx:elif="{{item.status === 'authorized'}}" class="auth-action auth-action-revoke" bindtap="onRevokeAuth" data-name="{{item.name}}">
          <text>撤销授权</text>
        </view>
        <view class="auth-divider" wx:if="{{index < authItems.length - 1}}" />
      </view>
    </view>

    <text class="footer-note">您的数据仅用于融资申请资料整理，不会用于其他用途。</text>
  </scroll-view>
</view>
