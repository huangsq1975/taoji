<view class="page-wrap">
  <navigation-bar title="历史对话" background="#fff" color="#172033" />
  <scroll-view scroll-y class="scroll-area">
    <view class="card">
      <view wx:for="{{historyList}}" wx:key="id" class="history-item" bindtap="onItemTap" data-title="{{item.title}}">
        <text class="history-title">{{item.title}}</text>
        <text class="history-preview">{{item.preview}}</text>
        <text class="history-time">{{item.time}}</text>
      </view>
    </view>
    <text class="footer-note">仅展示近7天对话记录</text>
  </scroll-view>
</view>
