<view class="page-wrap">
  <navigation-bar title="银行材料整理" background="#fff" color="#172033" />

  <!-- Row 1: Customer + Bank pickers -->
  <view class="selector-bar">
    <picker mode="selector" range="{{customerNames}}" value="{{selectedCustomerIdx}}"
      bindchange="onCustomerChange" disabled="{{customerNames.length === 0}}">
      <view class="selector-item">
        <text class="selector-label">客户</text>
        <text class="selector-val">{{selectedCustomerName}}</text>
        <text class="selector-arrow">▾</text>
      </view>
    </picker>
    <picker mode="selector" range="{{bankNames}}" value="{{selectedBankIdx}}"
      bindchange="onBankChange" disabled="{{bankNames.length === 0}}">
      <view class="selector-item selector-item-last">
        <text class="selector-label">银行</text>
        <text class="selector-val">{{selectedBankName}}</text>
        <text class="selector-arrow">▾</text>
      </view>
    </picker>
  </view>

  <!-- Row 2: Product picker -->
  <view class="product-bar">
    <picker mode="selector" range="{{productNames}}" value="{{selectedProductIdx}}"
      bindchange="onProductChange" disabled="{{productNames.length === 0}}">
      <view class="product-selector">
        <text class="selector-label">产品</text>
        <text class="product-val">{{selectedProductName}}</text>
        <text class="selector-arrow">▾</text>
      </view>
    </picker>
  </view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view wx:for="{{tabs}}" wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="onTabTap" data-key="{{item.key}}">
      <text>{{item.label}}</text>
    </view>
  </view>

  <scroll-view scroll-y class="scroll-area">

    <!-- 材料要求 tab -->
    <block wx:if="{{activeTab === 'requirements'}}">

      <!-- Product info card -->
      <view class="card" wx:if="{{selectedProduct}}">
        <text class="card-title">{{selectedProductName}}</text>
        <view class="info-row" wx:if="{{selectedProduct.loanAmount}}">
          <text class="label">参考额度</text>
          <text class="value">{{selectedProduct.loanAmount}}</text>
        </view>
        <view class="info-row" wx:if="{{selectedProduct.loanTerm}}">
          <text class="label">参考期限</text>
          <text class="value">{{selectedProduct.loanTerm}}</text>
        </view>
        <view class="info-row" wx:if="{{selectedProduct.description}}">
          <text class="label">产品说明</text>
          <text class="value">{{selectedProduct.description}}</text>
        </view>
        <view class="info-row" wx:if="{{selectedProduct.requirements}}">
          <text class="label">申请条件</text>
          <text class="value">{{selectedProduct.requirements}}</text>
        </view>
      </view>

      <!-- Loading state -->
      <view class="state-tip" wx:if="{{loadingMaterials}}">
        <text>加载材料要求中…</text>
      </view>

      <!-- Empty state -->
      <view class="state-tip" wx:elif="{{materialGroups.length === 0 && !loadingMaterials}}">
        <text>当前产品暂未配置材料清单</text>
      </view>

      <!-- Material groups -->
      <view wx:for="{{materialGroups}}" wx:key="category" wx:for-item="group" class="card">
        <text class="card-title">{{group.category}}</text>
        <view wx:for="{{group.items}}" wx:key="id" wx:for-item="item" class="material-row">
          <view class="material-info">
            <text class="material-name">{{item.name}}</text>
            <text class="material-source" wx:if="{{item.source || item.format}}">
              {{item.source}}{{item.source && item.format ? ' · ' : ''}}{{item.format}}
            </text>
            <text class="material-note" wx:if="{{item.note}}">{{item.note}}</text>
          </view>
          <view class="badge {{item.required ? 'badge-ok' : 'badge-gray'}}">
            <text>{{item.required ? '必填' : '选填'}}</text>
          </view>
        </view>
      </view>

      <view class="note-box" wx:if="{{materialGroups.length > 0}}">
        <text>顾问提示：以上为银行产品固定材料配置，客户资料缺口请切到「资料匹配」查看。</text>
      </view>

    </block>

    <!-- 资料匹配 tab -->
    <block wx:if="{{activeTab === 'match'}}">

      <!-- Summary header -->
      <view class="match-header card" wx:if="{{selectedCustomerName !== '请选择客户'}}">
        <text class="match-header-text">{{selectedCustomerName}} · {{selectedProductName}}</text>
        <text class="match-sub">已上传 {{customerDocs.length}} 份文件，对照银行材料要求匹配如下</text>
      </view>

      <view class="state-tip" wx:if="{{selectedCustomerIdx < 0}}">
        <text>请先在上方选择客户</text>
      </view>

      <view class="state-tip" wx:elif="{{matchGroups.length === 0}}">
        <text>暂无可匹配的材料要求</text>
      </view>

      <view wx:for="{{matchGroups}}" wx:key="category" wx:for-item="group" class="card">
        <text class="card-title">{{group.category}}</text>
        <view wx:for="{{group.items}}" wx:key="id" wx:for-item="item" class="material-row">
          <view class="material-info">
            <text class="material-name">{{item.name}}</text>
            <text class="material-source" wx:if="{{item.source}}">{{item.source}}</text>
          </view>
          <view class="badge {{item.matchClass}}">
            <text>{{item.matchStatus}}</text>
          </view>
        </view>
      </view>

      <!-- Create report task button -->
      <view class="card" wx:if="{{selectedCustomerIdx >= 0 && selectedProductIdx >= 0}}">
        <view class="report-btn {{creating ? 'report-btn-disabled' : ''}}" bindtap="onCreateReportTask">
          <text>{{creating ? '创建中…' : '生成 AI 填报任务'}}</text>
        </view>
        <text class="report-hint">AI 将根据材料配置自动填写字段草稿，顾问复核后可导出材料包</text>
      </view>

    </block>

    <!-- AI修改 tab -->
    <block wx:if="{{activeTab === 'ai'}}">
      <view class="card">
        <text class="card-title">AI 修改助手</text>
        <text class="card-note">告诉我材料说明哪里需要调整，AI 会生成修改建议。</text>
        <view class="ai-chat">
          <view wx:for="{{aiMessages}}" wx:key="{{index}}"
            class="ai-msg {{item.role === 'user' ? 'ai-msg-user' : 'ai-msg-ai'}}">
            <text>{{item.text}}</text>
          </view>
        </view>
        <view class="ai-input-row">
          <input class="ai-input" placeholder="例如：把流水缺口写得更具体"
            value="{{aiInput}}" bindinput="onAiInputChange"
            confirm-type="send" bindconfirm="onAiSend" />
          <view class="ai-send-btn" bindtap="onAiSend"><text>发送</text></view>
        </view>
      </view>
    </block>

    <view style="height: 40rpx" />
  </scroll-view>
</view>
