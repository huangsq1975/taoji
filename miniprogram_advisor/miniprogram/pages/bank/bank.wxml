<view class="page-wrap">
  <navigation-bar title="银行材料整理" background="#fff" color="#172033" />

  <!-- Selectors -->
  <view class="selector-bar">
    <picker mode="selector" range="{{customers}}" range-key="name"
      value="{{0}}" bindchange="onCustomerChange">
      <view class="selector-item">
        <text class="selector-label">客户</text>
        <text class="selector-val">{{customers[0].name}}</text>
        <text class="selector-arrow">▾</text>
      </view>
    </picker>
    <picker mode="selector" range="{{banks}}" range-key="name"
      value="{{0}}" bindchange="onBankChange">
      <view class="selector-item">
        <text class="selector-label">银行</text>
        <text class="selector-val">{{banks[0].name}}</text>
        <text class="selector-arrow">▾</text>
      </view>
    </picker>
  </view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view wx:for="{{tabs}}" wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="onTabTap" data-key="{{item.key}}">
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- Tab content -->
  <scroll-view scroll-y class="scroll-area">

    <!-- 材料要求 tab -->
    <block wx:if="{{activeTab === 'requirements'}}">
      <view class="card">
        <text class="card-title">建行善科贷 · 材料要求</text>
        <text class="card-note">这是银行产品固定资料配置，不判断当前客户是否已满足。</text>
        <view class="info-row"><text class="label">适用客群</text><text class="value">高新/专精特新，经营满2年，纳税和流水稳定</text></view>
        <view class="info-row"><text class="label">参考额度</text><text class="value">50-1000万</text></view>
        <view class="info-row"><text class="label">参考利率</text><text class="value">3.05%-4.20%</text></view>
        <view class="info-row"><text class="label">参考期限</text><text class="value">12-36个月</text></view>
      </view>
      <view class="card">
        <text class="card-title">基础主体资料</text>
        <view class="material-row">
          <view class="material-info"><text class="material-name">营业执照</text><text class="material-source">客户上传/C端 · 彩色扫描件</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">法人/实控人信息</text><text class="material-source">顾问录入 · 身份证明、联系方式</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
      </view>
      <view class="card">
        <text class="card-title">征信授权资料</text>
        <view class="material-row">
          <view class="material-info"><text class="material-name">企业征信授权</text><text class="material-source">银行制式授权 · 签字盖章版</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">法人征信授权</text><text class="material-source">银行制式授权 · 法人签字</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
      </view>
      <view class="card">
        <text class="card-title">经营财务资料</text>
        <view class="material-row">
          <view class="material-info"><text class="material-name">近12个月流水</text><text class="material-source">客户上传 · 银行流水或电子流水</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">纳税记录</text><text class="material-source">税务截图/授权导出 · 近12个月连续</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">科技资质证明</text><text class="material-source">客户上传 · 国高/科小/专精特新证书</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
      </view>
      <view class="card">
        <text class="card-title">银行制式表格</text>
        <view class="material-row">
          <view class="material-info"><text class="material-name">善科贷企业信息采集表</text><text class="material-source">银行制式表格 · 按产品字段填写</text></view>
          <view class="badge badge-ok"><text>必填</text></view>
        </view>
      </view>
      <view class="note-box">
        <text>顾问提示：材料要求来自银行产品口径配置，客户级缺口请切到"资料匹配"查看。</text>
      </view>
    </block>

    <!-- 资料匹配 tab -->
    <block wx:if="{{activeTab === 'match'}}">
      <view class="card">
        <text class="card-title">东莞某智能设备 · 建行善科贷 · 资料匹配</text>
        <text class="card-note">按当前客户已上传资料，对照银行产品要求判断状态。</text>
        <view class="material-row">
          <view class="material-info"><text class="material-name">营业执照</text><text class="material-source">客户/顾问已提供</text></view>
          <view class="badge badge-ok"><text>已满足</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">近12个月流水</text><text class="material-source">客户/顾问已提供</text></view>
          <view class="badge badge-ok"><text>已满足</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">科技资质证明</text><text class="material-source">客户/顾问已提供</text></view>
          <view class="badge badge-ok"><text>已满足</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">企业征信授权</text><text class="material-source">待补充或待识别</text></view>
          <view class="badge badge-warn"><text>缺失</text></view>
        </view>
        <view class="material-row">
          <view class="material-info"><text class="material-name">银行材料补充表</text><text class="material-source">待补充或待识别</text></view>
          <view class="badge badge-warn"><text>缺失</text></view>
        </view>
      </view>
    </block>

    <!-- AI修改 tab -->
    <block wx:if="{{activeTab === 'ai'}}">
      <view class="card">
        <text class="card-title">AI修改助手</text>
        <view class="ai-chat">
          <view wx:for="{{aiMessages}}" wx:key="text"
            class="ai-msg {{item.role === 'user' ? 'ai-msg-user' : 'ai-msg-ai'}}">
            <text>{{item.text}}</text>
          </view>
        </view>
        <view class="ai-input-row">
          <input class="ai-input" placeholder="例如：把流水缺口写得更具体"
            value="{{aiInput}}" bindinput="onAiInputChange"
            confirm-type="send" bindconfirm="onAiSend" />
          <view class="ai-send-btn" bindtap="onAiSend"><text>发送</text></view>
        </view>
      </view>
    </block>

    <view style="height: 40rpx" />
  </scroll-view>
</view>
