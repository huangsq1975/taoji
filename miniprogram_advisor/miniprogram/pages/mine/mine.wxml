<view class="page-wrap">
  <navigation-bar title="我的" background="#fff" color="#172033" />
  <scroll-view scroll-y class="scroll-area">
    <!-- Profile -->
    <view class="profile-card">
      <view class="avatar"><text class="avatar-icon">👨‍💼</text></view>
      <view class="profile-info">
        <text class="profile-name">{{advisor.name}}</text>
        <text class="profile-role">{{advisor.roleLabel}}</text>
      </view>
      <view class="status-badge"><text>在职</text></view>
    </view>

    <!-- Role info -->
    <view class="card">
      <text class="card-title">角色信息</text>
      <view class="info-row"><text class="label">所属机构</text><text class="value">{{advisor.institution}}</text></view>
      <view class="info-row"><text class="label">角色</text><text class="value">{{advisor.roleLabel}}</text></view>
      <view class="info-row"><text class="label">套餐</text><text class="value">{{planName}}</text></view>
    </view>

    <!-- My clients -->
    <view class="card" bindtap="onClientsTap">
      <view class="card-head-row">
        <text class="card-title" style="margin-bottom:0">我的客户</text>
        <text class="card-link">查看全部 ›</text>
      </view>
      <view class="info-row"><text class="label">在手客户</text><text class="value">{{totalClients}} 位</text></view>
      <view class="info-row"><text class="label">待补资料</text><text class="value">{{pendingClients}} 位</text></view>
      <view class="info-row"><text class="label">待复核</text><text class="value">{{reviewClients}} 位</text></view>
    </view>

    <!-- Quota -->
    <view class="card">
      <text class="card-title">调用次数</text>
      <view class="info-row"><text class="label">剩余调用</text><text class="value blue-text">{{quotaRemainingLabel}} 次</text></view>
      <view class="info-row"><text class="label">AI填表</text><text class="value">已用 {{quotaFill}} 次</text></view>
      <view class="info-row"><text class="label">材料包</text><text class="value">已用 {{quotaExport}} 次</text></view>
    </view>

    <!-- Recent activity -->
    <view class="card">
      <text class="card-title">近期动态</text>
      <view class="state-tip" wx:if="{{loadingActivity}}"><text>加载中…</text></view>
      <view class="state-tip" wx:elif="{{recentActivity.length === 0}}"><text>暂无近期动态</text></view>
      <view wx:else>
        <view wx:for="{{recentActivity}}" wx:key="id" class="activity-item">
          <view class="activity-body">
            <view class="activity-top">
              <text class="activity-title">{{item.title}}</text>
              <view class="badge {{item.statusClass}}"><text>{{item.statusLabel}}</text></view>
            </view>
            <text class="activity-sub">{{item.body}}</text>
            <text class="activity-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Invite -->
    <view class="invite-card" bindtap="onInviteTap">
      <view class="invite-left">
        <text class="invite-title">邀请客户</text>
        <text class="invite-sub">扫码绑定，资料直达您的工作台</text>
      </view>
      <view class="invite-icon-wrap">
        <text class="invite-icon">⬛</text>
      </view>
    </view>

    <!-- Settings -->
    <view class="card">
      <text class="card-title">设置</text>
      <view class="info-row"><text class="label">消息通知</text><text class="value">客户补资料、材料包待复核</text></view>
      <view class="info-row"><text class="label">隐私授权</text><text class="value">仅用于客户资料整理</text></view>
      <view class="info-row"><text class="label">帮助中心</text><text class="value">材料口径、AI修改助手说明</text></view>
    </view>

    <view style="height: 40rpx" />
  </scroll-view>

  <!-- QR Code Modal -->
  <view wx:if="{{qrVisible}}" class="qr-mask" bindtap="onCloseQrModal">
    <view class="qr-modal" catchtap="">
      <text class="qr-modal-title">专属邀请码</text>
      <text class="qr-modal-sub">客户微信扫码后自动绑定到您名下</text>

      <view class="qr-box">
        <view wx:if="{{qrLoading}}" class="qr-loading"><text>生成中…</text></view>
        <image wx:else src="{{qrSrc}}" class="qr-image" mode="aspectFit" />
      </view>

      <view class="qr-name"><text>{{advisor.name}} · {{advisor.institution}}</text></view>

      <view class="qr-actions">
        <view class="qr-btn-save" bindtap="onSaveQr">
          <text>保存到相册</text>
        </view>
        <view class="qr-btn-close" bindtap="onCloseQrModal">
          <text>关闭</text>
        </view>
      </view>
    </view>
  </view>
</view>
